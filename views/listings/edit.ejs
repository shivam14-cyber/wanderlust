<% layout("/layouts/boilerplate") %>

  <div class="row mt-4">
    <div class="col-8 offset-2">
      <form action="/listings/<%= listing._id %>?_method=PATCH" method="post" novalidate class="needs-validation" ,
        enctype="multipart/form-data">
        <div class="mb-3">
          <label class="form-label"> Title </label>
          <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control text-muted"
            required />
        </div>

        <div class="mb-3">
          <label class="form-label"> Description </label>
          <textarea name="listing[description]" cols="30" rows="5" class="form-control text-muted" required>
         <%= listing.description %></textarea>
        </div>

        <div class="mb-4">
          <label class="form-label  mb-3">
            Original Listing Image
          </label>
          <div class="card border-0 shadow-sm rounded-4 overflow-hidden w-50">
            <img src="<%= originalImage %>" class="img-fluid" style="height: 130px; width: 100%; object-fit: cover;">
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label"> Uplaod Image </label>
          <input type="file" name="listing[image]" class="form-control text-muted" />
        </div>

        <div class="row">
          <div class="col-lg-8 col-sm-12">
            <div class="mb-3">
              <label class="form-label">Country</label>
              <input type="text" name="listing[country]" placeholder="Enter the country" value="<%= listing.country %>"
                class="form-control text-muted" required />
            </div>
          </div>
          <div class="col-lg-4 col-sm-12">
            <div class="mb-3">
              <label class="form-label">Price</label>
              <input type="number" name="listing[price]" value="<%= listing.price %>" placeholder="Enter the price"
                class="form-control text-muted" required />
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-8 mb-3">
          <label class="form-label"> Location </label>
          <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control text-muted"
            required />
        </div>
         <div class="col-4 mb-3">
          <label class="form-label"> Category </label>
          <input type="text" name="listing[category]" value="<%= listing.category %>" class="form-control text-muted"  readonly
            required />
        </div>
        </div>
        <button class="btn btn-danger mb-4">Update Listing</button>
      </form>
    </div>
  </div>