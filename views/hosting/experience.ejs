<% layout("/layouts/privacyBoilerplate.ejs") %>

  <section class="container py-5">
    <div class="text-center">
      <h1 class="fw-bold display-4">
        Bring the best of your <br>
        city to life on Airbnb
      </h1>
      <p class="text-secondary fs-5 mt-3">
        Apply to join our marketplace of high-quality <br>
        experiences led by locals like you.
      </p>
    </div>

    <div class="row justify-content-center mt-5 g-4">
      <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?q=80&w=800"
          class="card-img-top" alt="horse">
          <div class="card-body text-center">
            <p class="small text-secondary mb-0">
              Arnold leads horseback tours <br>
              of Incan temples in Cusco
            </p>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=800"
          class="card-img-top" alt="car">
          <div class="card-body text-center">
           <p class="small text-secondary mb-0">
              Ryan celebrates the art of car <br>
              customisation in Los Angeles
            </p>
          </div>
        </div>
      </div>

      <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
          <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=800"
          class="card-img-top" alt="skating">
          <div class="card-body text-center">
            <p class="small text-secondary mb-0">
              Alicia shares skate moves on <br>
              the boardwalk in Venice Beach
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-5 pt-5">
     <h1 class="fw-bold display-5">
        Host one-of-a-kind <br>
        experiences of all kinds
      </h1>
    </div>

    <div class="row justify-content-center mt-5 g-5">
      <div class="col-md-4">
        <div class="d-flex align-items-start gap-3">
          <div class="fs-1">🏛️</div>
          <div>
            <h5 class="fw-bold mb-1">
              Show off your city
            </h5>
            <p class="text-secondary small mb-0">
              Lead unique tours of landmarks,
              museums or cultural hotspots.
            </p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="d-flex align-items-start gap-3">
          <div class="fs-1">🍜</div>
          <div>
            <h5 class="fw-bold mb-1">
              Share something tasty
            </h5>
            <p class="text-secondary small mb-0">
              Host cooking classes, food
              tours or dining experiences.
            </p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="d-flex align-items-start gap-3">
          <div class="fs-1">🏞️</div>
          <div>
            <h5 class="fw-bold mb-1">
              Lead an outdoor adventure
            </h5>
            <p class="text-secondary small mb-0">
              Guide nature hikes, water sports
              or wildlife expeditions.
            </p>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <div class="d-flex align-items-start gap-3">
          <div class="fs-1">🖼️</div>
          <div>
            <h5 class="fw-bold mb-1">
              Celebrate the arts
            </h5>
            <p class="text-secondary small mb-0">
              Explore galleries, shopping and
              fashion or run art workshops.
            </p>
          </div>
        </div>
      </div>


      <div class="col-md-4">
        <div class="d-flex align-items-start gap-3">
          <div class="fs-1">🏋️</div>
          <div>
            <h5 class="fw-bold mb-1">
              Teach fitness and self-care
            </h5>

            <p class="text-secondary small mb-0">
              Host workouts, wellness classes
              or beauty experiences.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

