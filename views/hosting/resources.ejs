            </p>

            <div class="row mt-4">
              <div class="col border rounded-4 py-2">
                <h6 class="fw-bold mb-0">
                  ★ 5.0
                </h6>
                <small class="text-secondary">
                  guest rating
                </small>
              </div>

              <div class="col border rounded-4 py-2 ms-2">
                <h6 class="fw-bold mb-0">
                  9
                </h6>
                <small class="text-secondary">
                  years hosting
                </small>
              </div>
            </div>
          </div>
        </div>
      </div>


      <div class="col-md-4">
        <div class="card border-0 rounded-5 shadow-sm text-center p-4">
          <img
          src="https://randomuser.me/api/portraits/women/68.jpg"
          class="rounded-circle mx-auto"
          width="100"
          height="100">

          <div class="card-body">
            <h3 class="fw-bold">
              Gloria
            </h3>

            <p class="text-secondary small">
              Madrid, Germany
            </p>

            <div class="row mt-4">
              <div class="col border rounded-4 py-2">
                <h6 class="fw-bold mb-0">
                  ★ 5.0
                </h6>
                <small class="text-secondary">
                  guest rating
                </small>
              </div>

              <div class="col border rounded-4 py-2 ms-2">
                <h6 class="fw-bold mb-0">
                  7
                </h6>
                <small class="text-secondary">
                  years hosting
                </small>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="text-center mt-5">
      <button class="btn btn-dark rounded-pill px-5">
        <i class="bi bi-search me-2"></i>
        Find a co-host
      </button>
    </div>
  </section>
