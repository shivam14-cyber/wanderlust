<% layout("/layouts/privacyBoilerplate.ejs") %>

  <section class="py-5">
    <div class="container">
      <div class="text-center mb-5">
        <h1 class="fw-bold display-2 lh-1">
          Accessibility <br> at Airbnb
        </h1>
        <p class="text-secondary mt-3">
          Here’s how we’re making it easier to travel with us.
        </p>
      </div>
      <div class="row align-items-center justify-content-center py-5">
        <div class="col-lg-4 text-center mb-4 mb-lg-0">
          <img
            src="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?q=80&w=500"
            alt="Phone UI"
            class="img-fluid rounded-5 shadow"
            style="max-height: 500px;"
          >
        </div>
        <div class="col-lg-4">
          <h2 class="fw-bold mb-3">
            Enhanced search filters
          </h2>

          <p class="text-secondary fs-5">
            We’ve simplified our accessibility filters to provide an even
            better search experience.
          </p>
        </div>

      </div>

    </div>

    <div class="bg-body-secondary py-5 mt-5">
      <div class="container">
        <div class="row align-items-center justify-content-center">
          <div class="col-lg-4 order-2 order-lg-1 mt-4 mt-lg-0">
            <h2 class="fw-bold mb-3">
              Accessibility review
            </h2>
            <p class="text-secondary fs-5">
              We review every accessibility feature submitted by stays hosts
              for accuracy.
            </p>
          </div>

          <div class="col-lg-4 text-center order-1 order-lg-2">
            <img
              src="https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?q=80&w=500"
              alt="Accessibility App"
              class="img-fluid rounded-5 shadow"
              style="max-height: 500px;"
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="container  bg-dark text-white py-5">

    <div class="row mb-5">
      <div class="col-lg-9">
        <h3 class="fw-bold display-6 mb-3">
          Digital accessibility at Airbnb
        </h3>

        <p class="text-secondary fs-5">
          Airbnb strives to conform with the European Accessibility Act
          and the Web Content Accessibility Guidelines (WCAG) 2.1 Level AA
          for our website and mobile applications.
        </p>
      </div>
    </div>

    <div class="row g-5 mb-5">

      <div class="col-lg-6">
        <h4 class="fw-bold mb-4">How we work</h4>

        <ul class="text-secondary lh-lg">
          <li>Incorporating digital accessibility best practices</li>
          <li>Providing ongoing accessibility training</li>
          <li>Engaging internal and external testers</li>
          <li>Maintaining cross-functional accessibility teams</li>
          <li>Training customer support agents</li>
        </ul>
      </div>

      <div class="col-lg-6">
        <h4 class="fw-bold mb-4">Feedback</h4>

        <p class="text-secondary lh-lg">
          We welcome your feedback on Airbnb’s digital accessibility
          practices. Please email us at
          <span class="text-white">
            digital-accessibility@airbnb.com
          </span>
        </p>
      </div>

    </div>

    <div class="row mb-5">
      <div class="col-lg-6">
        <h4 class="fw-bold mb-4">Dedicated teams</h4>

        <p class="text-secondary lh-lg">
          Airbnb has teams focused on building products that everyone can use.
          These teams work with engineers and designers to ensure accessibility.
        </p>
      </div>
    </div>

    <div class="row py-5 g-5 align-items-start">

      <div class="col-lg-5">
        <h2 class="fw-bold display-6 mb-4">
          Our digital access specifications
        </h2>

        <p class="text-secondary fs-5">
          We’re committed to designing an accessible experience
          across browsers and devices.
        </p>
      </div>

      <div class="col-lg-7">

        <div class="accordion accordion-flush" id="accordionExample">

          <div class="accordion-item bg-black border-secondary">
            <h2 class="accordion-header">
              <button
                class="accordion-button collapsed bg-black text-white shadow-none"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#collapseOne">

                Usability for browsers, assistive technology and devices
              </button>
            </h2>

            <div
              id="collapseOne"
              class="accordion-collapse collapse"
              data-bs-parent="#accordionExample">

              <div class="accordion-body text-secondary bg-black">
                Accessibility support across browsers and assistive tools.
              </div>
            </div>
          </div>

          <div class="accordion-item bg-black border-secondary">
            <h2 class="accordion-header">
              <button
                class="accordion-button collapsed bg-black text-white shadow-none"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#collapseTwo">

                Limitations and alternatives
              </button>
            </h2>

            <div
              id="collapseTwo"
              class="accordion-collapse collapse"
              data-bs-parent="#accordionExample">

              <div class="accordion-body text-secondary bg-black">
                Alternative methods are provided where limitations exist.
              </div>
            </div>
          </div>

          <div class="accordion-item bg-black border-secondary">
            <h2 class="accordion-header">
              <button
                class="accordion-button collapsed bg-black text-white shadow-none"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#collapseThree">

                Accessibility features
              </button>
            </h2>

            <div
              id="collapseThree"
              class="accordion-collapse collapse"
              data-bs-parent="#accordionExample">

              <div class="accordion-body text-secondary bg-black">
                Includes keyboard navigation and screen reader support.
              </div>
            </div>
          </div>

        </div>

      </div>

    </div>

    <div class="py-5">

      <h2 class="fw-bold display-6 mb-5">
        To champion accessibility, we work with:
      </h2>

      <div class="row g-4">

        <div class="col-6 col-md-3">
          <div class="border border-secondary rounded text-center p-4 text-secondary h-100">
            United Spinal
          </div>
        </div>

        <div class="col-6 col-md-3">
          <div class="border border-secondary rounded text-center p-4 text-secondary h-100">
            NCIL
          </div>
        </div>

        <div class="col-6 col-md-3">
          <div class="border border-secondary rounded text-center p-4 text-secondary h-100">
            AAPD
          </div>
        </div>

        <div class="col-6 col-md-3">
          <div class="border border-secondary rounded text-center p-4 text-secondary h-100">
            Red Costarricense
          </div>
        </div>

      </div>

    </div>

  </div>
